# NexusPipe Environment Configuration
# Copy this file to .env and fill in your values

# Application
NEXUSPIPE_APP_ENVIRONMENT=development
NEXUSPIPE_APP_PORT=8080

# Database
NEXUSPIPE_DATABASE_HOST=localhost
NEXUSPIPE_DATABASE_PORT=5432
NEXUSPIPE_DATABASE_USER=nexuspipe
NEXUSPIPE_DATABASE_PASSWORD=changeme
NEXUSPIPE_DATABASE_DBNAME=nexuspipe
NEXUSPIPE_DATABASE_SSLMODE=disable

# RabbitMQ
NEXUSPIPE_RABBITMQ_HOST=localhost
NEXUSPIPE_RABBITMQ_PORT=5672
NEXUSPIPE_RABBITMQ_USER=guest
NEXUSPIPE_RABBITMQ_PASSWORD=guest

# Redis
NEXUSPIPE_REDIS_HOST=localhost
NEXUSPIPE_REDIS_PORT=6379
NEXUSPIPE_REDIS_PASSWORD=

# Auth
NEXUSPIPE_AUTH_JWT_SECRET=your-jwt-secret-here-change-in-production
NEXUSPIPE_AUTH_BCRYPT_COST=12

# Logging
NEXUSPIPE_LOG_LEVEL=debug
NEXUSPIPE_LOG_FORMAT=console
